# ─────────────────────────────────────────
# Points Tracker — Dockge stack env template
# Paste into Dockge's .env editor and fill in.
# ─────────────────────────────────────────

# Image tag pulled from GHCR.
#   latest          → rolls forward with every push to main
#   main-<short>    → pin to a specific commit (e.g. main-ff6267f)
IMAGE_TAG=latest

# Public URL the SPA is reached at (no trailing slash).
# Used for CORS and for absolute share links the API generates.
APP_BASE_URL=https://pts.yourdomain.com

# Externally-exposed port (must be > 30000 and free on the host).
# Hit http://<truenas-host>:31080/ in a browser.
PROXY_PORT=31080

# Postgres
DB_NAME=points_tracker
DB_USER=pts_app
# Generate: openssl rand -base64 24
DB_PASSWORD=change_me_to_a_long_random_string

# Authentik (OIDC) — values from your Authentik provider for this app.
AUTHENTIK_AUTHORITY=https://auth.yourdomain.com/application/o/points-tracker/
AUTHENTIK_CLIENT_ID=points-tracker

# Share-link signing secret. 64+ random hex chars.
# Generate: openssl rand -hex 32
SHARE_TOKEN_SECRET=change_me_64_hex_chars
