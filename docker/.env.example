# ─────────────────────────────────────────
# Points Tracker — deployment env template
# Copy to `.env` and fill in. Never commit.
# ─────────────────────────────────────────

# Image tag to pull. Use "latest" for the rolling main build, or pin to a
# branch/sha tag (e.g. "main-ff6267f") for reproducible deployments.
IMAGE_TAG=latest

# Public URL the SPA is reached at. Used for CORS + share links.
APP_BASE_URL=https://pts.yourdomain.com

# Externally-exposed ports — both > 30000 by request.
PROXY_PORT=30080
DB_PORT=30432

# Database
DB_NAME=points_tracker
DB_USER=pts_app
DB_PASSWORD=change_me_to_a_long_random_string

# Authentik (OIDC)
AUTHENTIK_AUTHORITY=https://auth.yourdomain.com/application/o/points-tracker/
AUTHENTIK_CLIENT_ID=points-tracker

# Share-link signing secret. 64+ random hex chars.
# Generate: openssl rand -hex 32
SHARE_TOKEN_SECRET=change_me_64_hex_chars
