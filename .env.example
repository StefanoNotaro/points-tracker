# Copy to .env and fill in values. Never commit .env.

# Database
DB_USER=pts_app
DB_PASSWORD=<strong-random-password>
DB_CONNECTION_STRING=Host=db;Port=5432;Database=points_tracker;Username=pts_app;Password=<password>

# Authentik OIDC
AUTHENTIK_AUTHORITY=https://auth.yourdomain.com/application/o/points-tracker/
AUTHENTIK_CLIENT_ID=points-tracker

# Share token signing secret — generate with: openssl rand -hex 32
SHARE_TOKEN_SECRET=<64-char-hex>

# Application
APP_BASE_URL=https://pts.yourdomain.com

# TLS certificates directory on host
TLS_CERT_PATH=/mnt/certs/pts
